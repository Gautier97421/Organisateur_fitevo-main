generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   // rouge, bleu, vert, jaune, orange, mauve
  createdAt DateTime @default(now()) @map("created_at")
  
  users     User[]
  
  @@map("roles")
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  username              String?  @unique // Pseudo choisi lors de la première connexion
  password              String?  // Optionnel - défini lors de la première connexion
  name                  String
  role                  String   @default("employee") // "employee", "admin", "superadmin"
  roleId                String?  @map("role_id") // Référence vers le rôle personnalisé
  active                Boolean  @default(true)
  isFirstLogin          Boolean  @default(true) @map("is_first_login")
  remoteWorkEnabled     Boolean  @default(false) @map("remote_work_enabled")
  hasCalendarAccess     Boolean  @default(true) @map("has_calendar_access")
  hasEventProposalAccess Boolean @default(true) @map("has_event_proposal_access")
  hasWorkScheduleAccess Boolean  @default(true) @map("has_work_schedule_access")
  hasWorkPeriodAccess   Boolean  @default(true) @map("has_work_period_access")
  hasManagerAccess      Boolean  @default(false) @map("has_manager_access")
  profilePhoto          String?  @map("profile_photo")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  
  employeeRole      Role?          @relation(fields: [roleId], references: [id])
  events            Event[]
  registrations     Registration[]
  calendarEvents    CalendarEvent[]
  tasks             Task[]
  workSchedules     WorkSchedule[]
  timeEntries       TimeEntry[]
  userGyms          UserGym[]
  resetTokens       PasswordResetToken[]
  conversationMembers ConversationMember[]
  messages          Message[]

  @@map("users")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String?
  maxCapacity Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  userId      String   @map("user_id")
  
  user          User           @relation(fields: [userId], references: [id])
  sessions      Session[]
  registrations Registration[]
  
  @@map("events")
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  eventId     String   @map("event_id")
  
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model Participant {
  id        String   @id @default(cuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  registrations Registration[]
  
  @@map("participants")
}

model Registration {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  participantId String   @map("participant_id")
  userId        String   @map("user_id")
  status        String   @default("confirmed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
  
  @@unique([eventId, participantId])
  @@map("registrations")
}

model CalendarEvent {
  id               String    @id @default(cuid())
  title            String
  description      String?
  location         String    @default("")
  eventDate        DateTime  @map("event_date")
  eventTime        String?   @map("event_time")
  durationMinutes  Int       @default(60) @map("duration_minutes")
  createdByEmail   String    @map("created_by_email")
  createdByName    String    @map("created_by_name")
  status           String    @default("pending") // pending, approved, rejected
  rejectionReason  String?   @map("rejection_reason")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  userId           String    @map("user_id")
  
  user      User            @relation(fields: [userId], references: [id])
  reminders EventReminder[]
  
  @@map("calendar_events")
}

model EventReminder {
  id             String    @id @default(cuid())
  eventId        String    @map("event_id")
  reminderDate   DateTime  @map("reminder_date")
  recipientType  String    @map("recipient_type") // all, admins, employees
  customMessage  String?   @map("custom_message")
  createdBy      String    @map("created_by")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  
  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("event_reminders")
}

model Gym {
  id                String     @id @default(cuid())
  name              String
  address           String?
  isActive          Boolean    @default(true) @map("is_active")
  wifiRestricted    Boolean    @default(false) @map("wifi_restricted")
  wifiSsid          String?    @map("wifi_ssid")
  ipAddress         String?    @map("ip_address")
  qrCodeEnabled     Boolean    @default(false) @map("qr_code_enabled")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  tasks              Task[]
  timeEntries        TimeEntry[]
  userGyms           UserGym[]
  workSchedules      WorkSchedule[]
  cashRegisterFields CashRegisterField[]
  
  @@map("gyms")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("checkbox") // checkbox, text, qcm
  period      String?   // matin, aprem, journee
  subPeriod   String?   @map("sub_period") // debut, milieu, fin (pour matin et aprem uniquement)
  options     Json?     // Pour les QCM
  required    Boolean   @default(true)
  status      String    @default("pending") // pending, in_progress, completed
  priority    String    @default("medium") // low, medium, high
  assignedTo  String?   @map("assigned_to")
  dueDate     DateTime? @map("due_date")
  gymId       String?   @map("gym_id")
  roleIds     Json?     @map("role_ids") // IDs des rôles autorisés à voir cette tâche
  orderIndex  Int       @default(0) @map("order_index")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  userId      String    @map("user_id")
  
  user User  @relation(fields: [userId], references: [id])
  gym  Gym?  @relation(fields: [gymId], references: [id])
  
  @@map("tasks")
}

model WorkSchedule {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  employeeEmail    String   @map("employee_email")
  employeeName     String   @map("employee_name")
  gymId            String?  @map("gym_id")
  date             DateTime @map("work_date")
  startTime        String   @map("start_time")
  endTime          String   @map("end_time")
  breakDuration    Int      @default(0) @map("break_duration") // durée de pause en minutes
  breakStartTime   String?  @map("break_start_time") // heure de début de pause
  endDate          DateTime? @map("end_date")   // fin de période pour les congés
  label            String   @default("travail") // travail, conges
  period           String?  // matin, aprem, journee (période lancée par employé)
  subPeriod        String?  @map("sub_period") // debut, milieu, fin
  type             String   @default("work") // work, break, absence
  status           String   @default("scheduled") // scheduled, confirmed, completed
  notes            String?
  isTemporary      Boolean  @default(false) @map("is_temporary") // true = période lancée par employé, false = calendrier permanent
  tasksCompleted   Int      @default(0) @map("tasks_completed") // Nombre de tâches complétées en temps réel
  totalTasks       Int      @default(0) @map("total_tasks") // Nombre total de tâches pour cette période
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  user User  @relation(fields: [userId], references: [id])
  gym  Gym?  @relation(fields: [gymId], references: [id])
  
  @@map("work_schedules")
}

model AllowedNetwork {
  id          String   @id @default(cuid())
  networkName String   @map("network_name")
  networkSsid String   @map("network_ssid")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("allowed_networks")
}

model AppConfig {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  value         String?  @db.Text
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String   @map("updated_by")

  @@map("app_config")
}

model NewMemberInstructionItem {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?  @db.Text
  orderIndex    Int      @map("order_index")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("new_member_instruction_items")
}

model TimeEntry {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  gymId         String   @map("gym_id")
  employeeName  String   @map("employee_name")
  employeeEmail String   @map("employee_email")
  checkInTime   DateTime @map("check_in_time")
  createdAt     DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  @@map("time_entries")
}

model UserGym {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gymId     String   @map("gym_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  @@unique([userId, gymId])
  @@map("user_gyms")
}

model CustomPage {
  id          String   @id @default(cuid())
  title       String   // Titre de la page (ex: "Nouveau Adhérent", "Procédure Fermeture")
  icon        String   // Nom de l'icône Lucide (ex: "UserPlus", "Lock")
  description String?  @db.Text
  orderIndex  Int      @map("order_index")
  isActive    Boolean  @default(true) @map("is_active")
  roleIds     Json?    @map("role_ids") // IDs des rôles autorisés à voir cette page
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  items CustomPageItem[]
  
  @@map("custom_pages")
}

model CustomPageItem {
  id          Int        @id @default(autoincrement())
  pageId      String     @map("page_id")
  title       String
  description String?    @db.Text
  orderIndex  Int        @map("order_index")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  page CustomPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  @@map("custom_page_items")
}

model CashRegisterField {
  id          String   @id @default(cuid())
  label       String   // ex: "Nombre inscription", "Nombre de rendez vous"
  fieldType   String   @default("number") @map("field_type") // number, text, checkbox
  isRequired  Boolean  @default(false) @map("is_required")
  orderIndex  Int      @default(0) @map("order_index")
  gymId       String?  @map("gym_id") // Si null, appliqué à tous les salles
  period      String?  // matin, aprem, journee (si spécifié)
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  gym Gym? @relation(fields: [gymId], references: [id], onDelete: SetNull)
  
  @@map("cash_register_fields")
}

// Brouillard de caisse : mouvements enregistrés pendant une période de travail
// (encaissements et "non rendu" — monnaie non rendue au client).
model CashMovement {
  id           String   @id @default(cuid())
  userEmail    String   @map("user_email")
  userName     String?  @map("user_name")
  gymId        String?  @map("gym_id")
  period       String   // matin, aprem, journee
  movementDate DateTime @map("movement_date")
  entryMonth   String   @map("entry_month") // Format YYYY-MM
  type         String   // "encaissement" | "non_rendu"
  amount       Float
  label        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userEmail, movementDate])
  @@map("cash_movements")
}

model CashRegisterEntry {
  id            String   @id @default(cuid())
  entryDate     DateTime @map("entry_date")
  entryMonth    String   @map("entry_month") // Format YYYY-MM pour comparaisons mensuelles
  period        String   // matin, aprem, journee
  gymId         String?  @map("gym_id")
  userEmail     String   @map("user_email")
  userName      String?  @map("user_name")
  totalRegister Float    @map("total_register")
  cashAmount    Float    @map("cash_amount")
  coinsDetail   String?  @map("coins_detail") @db.Text
  notes         String?  @db.Text
  customValues  Json?    @map("custom_values")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("cash_register_entries")
}

model ScheduledEvent {
  id               String   @id @default(cuid())
  title            String
  description      String?  @db.Text
  eventDate        DateTime @map("event_date")
  startTime        String?  @map("start_time")
  endTime          String?  @map("end_time")
  assignType       String?  @map("assign_type") // employee, role (optionnel)
  assignedTo       String?  @map("assigned_to") // ID employe ou role (optionnel)
  assignedEmployeeEmail String? @map("assigned_employee_email")
  assignedRoleId   String?  @map("assigned_role_id")
  requiresValidation Boolean @default(true) @map("requires_validation")
  status           String   @default("pending") // pending, moved, overdue_notified
  validationNotifiedAt DateTime? @map("validation_notified_at")
  createdByEmail   String   @map("created_by_email")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  validations ScheduledEventValidation[]
  
  @@map("scheduled_events")
}

model ScheduledEventValidation {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  userEmail String   @map("user_email")
  validated Boolean  @default(false)
  validatedAt DateTime? @map("validated_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  event ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, userEmail])
  @@map("scheduled_event_validations")
}

// ─────────────────────────────────────────────────────────────
// Module Communication (messagerie, groupes, dossiers de rapports)
// ─────────────────────────────────────────────────────────────

model Conversation {
  id               String   @id @default(cuid())
  type             String   @default("direct") // "direct" | "group"
  name             String?  // nom du groupe (null pour les directs)
  createdBy        String   @map("created_by")
  lastMessageAt    DateTime? @map("last_message_at")
  pinnedMessageId  String?  @map("pinned_message_id") // ID du message épinglé (sans relation pour éviter le cycle)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  members  ConversationMember[]
  messages Message[]
  folders  Folder[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  role           String    @default("member") // "admin" | "member" (rôle dans le groupe)
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String    @db.Text
  attachmentId   String?   @map("attachment_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")
  deletedAt      DateTime? @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachment   Attachment?  @relation(fields: [attachmentId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Folder {
  id             String   @id @default(cuid())
  name           String
  scope          String   @default("shared") // "shared" (global, géré admin) | "group"
  conversationId String?  @map("conversation_id") // requis si scope="group"
  parentId       String?  @map("parent_id")       // sous-dossiers
  visibility     String   @default("all")         // "all" | "admins" | "roles" | "users" (pour scope="shared")
  roleIds        Json?    @map("role_ids")         // IDs des rôles autorisés si visibility="roles"
  userIds        Json?    @map("user_ids")         // IDs des utilisateurs autorisés si visibility="users"
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent       Folder?       @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Folder[]      @relation("FolderTree")
  attachments  Attachment[]

  @@index([scope])
  @@index([conversationId])
  @@map("folders")
}

model Attachment {
  id         String   @id @default(cuid())
  fileName   String   @map("file_name")   // nom d'affichage (fourni par l'utilisateur)
  storedName String   @map("stored_name") // nom physique sur disque (aléatoire)
  mimeType   String   @map("mime_type")
  size       Int
  folderId   String?  @map("folder_id")   // si déposé dans un dossier
  uploadedBy String   @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  folder   Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([folderId])
  @@map("attachments")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
