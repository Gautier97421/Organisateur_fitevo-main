# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=fitevo_db
POSTGRES_USER=fitevo
POSTGRES_PASSWORD=devpassword

# ── Database URL ──────────────────────────────
# Dev: localhost (DB in Docker, app on host)
# Prod: db (both in Docker on same network)
DATABASE_URL="postgresql://fitevo:devpassword@localhost:5432/fitevo_db?schema=public"

# ── NextAuth.js ───────────────────────────────
# PRODUCTION: replace with `openssl rand -base64 32`
NEXTAUTH_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ── Admin account (synced on every boot) ──────
ADMIN_EMAIL=admin@fitevo.com
ADMIN_PASSWORD=Admin@Fitevo2024!

# ── Application ───────────────────────────────
PORT=3000
NODE_ENV=development
